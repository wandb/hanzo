# Optional dev bundle identifier used by scripts/dev-run.sh
# HANZO_DEV_BUNDLE_IDENTIFIER=com.hanzo.app.dev
# Optional dev app display name and install path used by scripts/dev-run.sh
# HANZO_DEV_APP_NAME=Hanzo Dev
# HANZO_DEV_APP_ROOT=$HOME/.local/share/hanzo/Hanzo\ Dev.app
# Optional override path for bundling llama-server into the dev app bundle
# HANZO_LLAMA_SERVER_PATH=/absolute/path/to/llama-server
# Optional llama.cpp release override (requires matching sha256)
# HANZO_LLAMA_RELEASE_TAG=b8355
# HANZO_LLAMA_RELEASE_SHA256=43e831c4ccf785dfd4c4197e00fbba309823d4088a5c40def5d4d934d6aa6f9b
